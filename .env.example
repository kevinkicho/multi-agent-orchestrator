# Required: Path to the opencode project root (contains src/index.ts with the serve command)
# This is needed to spawn opencode serve instances for each project agent.
# Example: If you cloned opencode to ~/opencode, set:
OPENCODE_DIR=C:\Users\you\path\to\opencode

# Optional: API keys for LLM providers (also settable via the dashboard)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=
# TOGETHER_API_KEY=
# DEEPSEEK_API_KEY=
# FIREWORKS_API_KEY=
# OPENCODE_GO_API_KEY=

# Optional: GitHub Personal Access Token (classic) exposed to worker agents.
# Used for pushing branches, opening PRs, reading issues, etc. Scope it to the
# minimum your projects need (typically: repo, workflow). Leave blank to disable.
# GITHUB_TOKEN=
