# Atomic-write temp files — if the process crashes between write and rename,
# these orphans get left behind. They are never meant to be committed.
*.json.tmp.*

# Test temp directories
src/tests/.test-tmp-*/

# Lockfile (regenerated by bun install)
bun.lock
